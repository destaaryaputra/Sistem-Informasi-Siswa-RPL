{
  "version": 2,
  "regions": ["sin1"],
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.8.0" }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/(.*)", "dest": "/api/bridge.php?file=$1" }
  ]
}